# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Firebase Admin — path tới service account JSON
# Firebase Admin project configuration
FIREBASE_PROJECT_ID=tanle-dev
FIREBASE_STORAGE_BUCKET=tanle-dev.firebasestorage.app

GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Sentry DSN cho backend — lấy từ https://sentry.io/ → Settings → Client Keys
# Để trống = tắt Sentry (chỉ bật khi NODE_ENV=production + có DSN)
SENTRY_DSN=

# Node environment (production / development)
NODE_ENV=development
